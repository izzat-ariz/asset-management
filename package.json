{
  "name": "asset-management",
  "version": "1.0.0",
  "description": "Simple asset management app with React, Express, and Supabase",
  "scripts": {
    "start": "concurrently \"nodemon server/index.js\" \"npm --prefix client run dev\"",
    "server": "nodemon server/index.js",
    "client": "npm --prefix client run dev"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.2"
  }
}
